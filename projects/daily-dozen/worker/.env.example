# Copy to .env and fill in. NEVER commit .env — this repo is public and GitHub
# Pages serves it verbatim, so a committed key is a published key.

# YouTube Data API v3 key. Google Cloud Console -> APIs & Services -> Credentials.
# Server-side secret; it never ships to the browser. Discovery cannot work
# without it — there is no honest client-only fallback.
YOUTUBE_API_KEY=

# Supabase project REST endpoint. Same project as Ride Report (shared org, free
# tier caps at two projects), so this is Ride Report's URL.
SUPABASE_URL=https://itapesopzbqguatkwmjq.supabase.co

# The SECRET key (sb_secret_...), NOT the publishable/anon key. Dashboard ->
# Project Settings -> API Keys -> reveal the secret one. It bypasses RLS;
# shorts_feeds has no insert policy, so nothing else can write. This is the SAME
# secret already in ../../ride-report/worker/.env — the two workers share it.
SUPABASE_SECRET_KEY=sb_secret_...

# Set to 1 to skip the YouTube API entirely and build the dozen from a canned
# candidate set (worker/mock/videos.sample.json). Lets the full filter -> rank ->
# upsert pipeline run on any machine without a key or quota.
MOCK_YOUTUBE=

# ===== Optional tuning (defaults shown) — Phase 4 lifts these into config so a
# second region or a longer-Short experiment is a value change, not a code one.

# Region + language bias for discovery.
# REGION=US
# RELEVANCE_LANGUAGE=en

# search.list query term. Required by the API — an unanchored search returns
# nothing — so this anchors to short-form; the velocity rank does the curation.
# SEARCH_QUERY=#shorts

# Keep only videos at or under this many seconds (biases toward true Shorts;
# the Data API has no isShort flag).
# MAX_DURATION_SEC=60

# Target dozen size. Not a hard floor: a thin day writes fewer and flags it.
# DOZEN_SIZE=12

# How far back search.list looks, in hours. Recency is what surfaces *trending*
# rather than all-time-popular.
# PUBLISHED_WITHIN_HOURS=48

# Days of feed history to keep. Old rows are pruned only after a new one lands.
# RETENTION_DAYS=14
