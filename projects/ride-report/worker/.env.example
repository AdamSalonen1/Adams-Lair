# Copy to .env and fill in. NEVER commit .env — this repo is public and
# GitHub Pages serves it verbatim, so a committed key is a published key.

# Supabase project REST endpoint.
SUPABASE_URL=https://your-project.supabase.co

# The SECRET key (formerly "service_role"), NOT the publishable/anon key.
# Dashboard -> Project Settings -> API Keys -> reveal the secret one.
# It bypasses RLS; the reports table has no insert policy, so nothing else works.
SUPABASE_SERVICE_KEY=sb_secret_...

# Set to 1 to skip the Claude CLI entirely and emit a canned payload.
# Lets the full pipeline run on any machine without spending subscription quota.
MOCK_SYNTH=

# Optional overrides — defaults are Fargo, ND from the project plan.
# RIDE_LAT=46.8772
# RIDE_LON=-96.7898
# RIDE_TIMEZONE=America/Chicago
# CLAUDE_MODEL=sonnet
